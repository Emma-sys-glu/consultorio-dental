@startuml
title Diagrama de casos de uso UML - Consultorio Dental

left to right direction
skinparam shadowing false

actor "Usuario autenticado" as AuthUser <<abstract>>
actor "Administrador" as Admin
actor "Recepcionista" as Recepcionista
actor "Dentista" as DentistaActor

AuthUser <|-- Admin
AuthUser <|-- Recepcionista
AuthUser <|-- DentistaActor

rectangle "Consultorio Dental" <<system>> {
  usecase "Iniciar sesion" as UC_Login
  usecase "Cerrar sesion" as UC_Logout
  usecase "Cambiar contrasena" as UC_Password

  usecase "Consultar home" as UC_Home
  usecase "Consultar calendario" as UC_Calendar

  usecase "Gestionar pacientes" as UC_Pacientes
  usecase "Registrar paciente" as UC_Paciente_Create
  usecase "Editar paciente" as UC_Paciente_Update
  usecase "Eliminar paciente" as UC_Paciente_Delete
  usecase "Buscar paciente por nombre" as UC_Paciente_Search

  usecase "Gestionar citas" as UC_Citas
  usecase "Agendar cita" as UC_Cita_Create
  usecase "Reprogramar cita" as UC_Cita_Update
  usecase "Cancelar cita" as UC_Cita_Cancel

  usecase "Gestionar expedientes" as UC_Expedientes
  usecase "Registrar expediente" as UC_Exp_Create
  usecase "Adjuntar documento clinico" as UC_Doc_Create
  usecase "Eliminar documento clinico" as UC_Doc_Delete

  usecase "Gestionar tratamientos" as UC_Tratamientos
  usecase "Emitir recetas" as UC_Recetas
  usecase "Gestionar dentistas" as UC_Dentistas
  usecase "Gestionar inventario" as UC_Inventario
}

Admin --> UC_Login
Recepcionista --> UC_Login
DentistaActor --> UC_Login

AuthUser --> UC_Logout
AuthUser --> UC_Password
AuthUser --> UC_Home
AuthUser --> UC_Calendar

Recepcionista --> UC_Pacientes
Recepcionista --> UC_Citas

DentistaActor --> UC_Expedientes
DentistaActor --> UC_Tratamientos
DentistaActor --> UC_Recetas

Admin --> UC_Pacientes
Admin --> UC_Citas
Admin --> UC_Expedientes
Admin --> UC_Tratamientos
Admin --> UC_Recetas
Admin --> UC_Dentistas
Admin --> UC_Inventario

UC_Pacientes .> UC_Paciente_Create : <<include>>
UC_Pacientes .> UC_Paciente_Update : <<include>>
UC_Pacientes .> UC_Paciente_Delete : <<include>>
UC_Pacientes .> UC_Paciente_Search : <<include>>

UC_Citas .> UC_Cita_Create : <<include>>
UC_Citas .> UC_Cita_Update : <<include>>
UC_Citas .> UC_Cita_Cancel : <<extend>>
UC_Home .> UC_Calendar : <<include>>

UC_Expedientes .> UC_Exp_Create : <<include>>
UC_Exp_Create .> UC_Doc_Create : <<extend>>
UC_Expedientes .> UC_Doc_Delete : <<extend>>

@enduml
