@startuml
title Diagrama de componentes detallado - Consultorio Dental

skinparam shadowing false
skinparam componentStyle uml2
skinparam linetype ortho

actor "Usuario Web" as User

interface "HTTP/HTML" as IHtml
interface "ORM Eloquent" as IOrm
interface "Filesystem API" as IFs
interface "SQL" as ISql

component "Blade UI" <<boundary>> as Blade {
  component "Layout principal" as Layout
  component "Vistas de modulos" as ModuleViews
  component "Formularios Bootstrap" as Forms
}

component "Router Laravel" <<router>> as Router
component "Middleware" <<middleware>> as Middleware {
  component "auth" as AuthMiddleware
  component "csrf" as CsrfMiddleware
}

component "Controladores" <<control>> as Controllers {
  component "DashboardController" as Dashboard
  component "AuthController" as AuthController
  component "CitaController" as CitaController
  component "ExpedienteController" as ExpedienteController
  component "Controladores CRUD" as CrudControllers
}

component "Modelos Eloquent" <<entity>> as Models {
  component "Paciente" as Paciente
  component "Dentista" as Dentista
  component "Cita" as Cita
  component "Expediente" as Expediente
  component "Tratamiento" as Tratamiento
  component "Receta" as Receta
  component "Inventario" as Inventario
}

component "Storage Laravel" <<service>> as Storage
database "PostgreSQL" <<database>> as DB
folder "storage/app/public" <<artifact>> as PublicStorage

User --> IHtml
IHtml - Blade
Blade --> Router : envia formularios
Router --> Middleware : canaliza peticion
Middleware --> Controllers : peticion validada
Controllers --> IOrm
IOrm - Models
Models --> ISql
ISql - DB
Controllers --> IFs
IFs - Storage
Storage --> PublicStorage : guarda documentos
Controllers --> Blade : retorna vista / redirect

@enduml
