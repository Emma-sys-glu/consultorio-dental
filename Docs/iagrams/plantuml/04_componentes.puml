@startuml
title Diagrama de componentes UML - Arquitectura Laravel MVC

skinparam shadowing false
skinparam componentStyle uml2
skinparam linetype ortho

actor "Usuario Web" as Usuario

interface "HTTP" as HTTP
interface "Blade Render" as BladeRender
interface "Validation" as ValidationPort
interface "Eloquent ORM" as ORM
interface "Filesystem" as FS
interface "SQL" as SQL

component "Navegador" <<client>> as Browser

component "Vistas Blade" <<boundary>> as Views {
  component "Layout principal" as Layout
  component "Vistas CRUD" as CrudViews
  component "Formularios Bootstrap" as Forms
}

component "Laravel Router" <<router>> as Router

component "Middleware HTTP" <<middleware>> as Middleware {
  component "Authenticate" as AuthMiddleware
  component "VerifyCsrfToken" as CsrfMiddleware
}

component "Controladores" <<control>> as Controllers {
  component "DashboardController" as DashboardController
  component "AuthController" as AuthController
  component "CitaController" as CitaController
  component "ExpedienteController" as ExpedienteController
  component "CRUD Controllers" as CrudControllers
}

component "Validacion Laravel" <<service>> as Validator

component "Modelos Eloquent" <<entity>> as Models {
  component "Paciente" as Paciente
  component "Dentista" as Dentista
  component "Cita" as Cita
  component "Expediente" as Expediente
  component "Tratamiento" as Tratamiento
  component "Receta" as Receta
  component "Inventario" as Inventario
  component "User" as UserModel
}

component "Storage Laravel" <<service>> as Storage
database "PostgreSQL" <<database>> as Database
folder "storage/app/public" <<artifact>> as PublicDisk

Usuario --> Browser
Browser - HTTP
HTTP --> Router
Router --> Middleware
Middleware --> Controllers
Controllers - ValidationPort
ValidationPort --> Validator
Controllers - ORM
ORM --> Models
Models - SQL
SQL --> Database
Controllers - FS
FS --> Storage
Storage --> PublicDisk
Controllers - BladeRender
BladeRender --> Views
Views --> Browser : HTML/CSS/Bootstrap

@enduml
