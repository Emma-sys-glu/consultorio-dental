@startuml
title Diagrama de robustez - Crear expediente con documentos

skinparam shadowing false
left to right direction

actor "Usuario autenticado" as Usuario

boundary "Formulario crear expediente\nexpedientes/create.blade.php" as Form
boundary "Listado de expedientes\nexpedientes/index.blade.php" as Listado

control "routes/web.php" as Routes
control "Middleware Auth" as Auth
control "Middleware CSRF" as Csrf
control "ExpedienteController" as ExpedienteController
control "Validador Laravel" as Validator
control "Storage facade" as Storage

entity "Paciente" as Paciente
entity "Expediente" as Expediente
entity "ExpedienteDocumento" as Documento
database "PostgreSQL" as DB
collections "storage/app/public" as FileSystem

Usuario --> Form : captura datos clinicos\ny adjunta PDF/imagen
Form --> Routes : POST /vista-expedientes/guardar
Routes --> Auth : verifica sesion
Routes --> Csrf : verifica token
Routes --> ExpedienteController : storeWeb(request)
ExpedienteController --> Validator : valida campos y archivos
ExpedienteController --> Paciente : busca paciente_id
Paciente --> DB : SELECT pacientes
ExpedienteController --> Expediente : create(datos)
Expediente --> DB : INSERT expedientes
ExpedienteController --> Storage : guarda archivos
Storage --> FileSystem : almacena PDF/JPG/PNG
ExpedienteController --> Documento : create(metadata)
Documento --> DB : INSERT expediente_documentos
ExpedienteController --> Listado : redirect con mensaje
Listado --> Usuario : muestra expediente creado

@enduml
